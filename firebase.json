{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "README.md",
      "SETUP.md",
      ".git",
      "node_modules"
    ],
    "rewrites": [
      { "source": "/app", "destination": "/dashboard.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|html|css)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
